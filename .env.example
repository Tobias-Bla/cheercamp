# Neon pooled connection for the running app
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-ENDPOINT-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Neon direct connection for Prisma CLI / migrations
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-ENDPOINT.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Public site URL used for Stripe success/cancel redirects
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# Optional basic auth for /admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
