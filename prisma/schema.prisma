generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum StuntFormat {
  PARTNER_STUNT
  GROUP_STUNT
}

enum PrivateInterest {
  NONE
  PAIR_60
  PAIR_90
  GROUP_60
  GROUP_90
  INDIVIDUAL_60
  INDIVIDUAL_90
}

model Booking {
  id                      String           @id @default(cuid())
  userId                  String?          @map("user_id")
  user                    User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  status                  BookingStatus    @default(PENDING)
  campSlug                String           @map("camp_slug")
  campTitle               String           @map("camp_title")
  campLocation            String           @map("camp_location")
  campStartDate           DateTime?        @map("camp_start_date")
  campEndDate             DateTime?        @map("camp_end_date")
  participantFirstName    String           @map("participant_first_name")
  participantLastName     String           @map("participant_last_name")
  participantBirthDate    DateTime         @map("participant_birth_date")
  contactName             String           @map("contact_name")
  contactEmail            String           @map("contact_email")
  contactPhone            String           @map("contact_phone")
  emergencyContactName    String           @map("emergency_contact_name")
  emergencyContactPhone   String           @map("emergency_contact_phone")
  experienceLevel         ExperienceLevel  @map("experience_level")
  stuntFormat             StuntFormat      @map("stunt_format")
  teamName                String?          @map("team_name")
  stuntPartnerOrGroup     String?          @map("stunt_partner_or_group")
  participantMobile       String           @map("participant_mobile")
  saturdayWish            String?          @map("saturday_wish") @db.Text
  privateInterest         PrivateInterest  @default(NONE) @map("private_interest")
  allergies               String?          @db.Text
  notes                   String?          @db.Text
  photoConsent            Boolean          @default(false) @map("photo_consent")
  acceptedTerms           Boolean          @default(false) @map("accepted_terms")
  stripeCheckoutSessionId String?          @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?          @map("stripe_payment_intent_id")
  amountCents             Int              @map("amount_cents")
  currency                String           @default("EUR")
  paidAt                  DateTime?        @map("paid_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  @@index([campSlug, createdAt])
  @@index([contactEmail])
  @@index([status])
  @@index([userId])
  @@map("bookings")
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  passwordHash          String        @map("password_hash")
  name                  String?
  participantFirstName  String?       @map("participant_first_name")
  participantLastName   String?       @map("participant_last_name")
  participantBirthDate  DateTime?     @map("participant_birth_date")
  contactPhone          String?       @map("contact_phone")
  participantMobile     String?       @map("participant_mobile")
  emergencyContactName  String?       @map("emergency_contact_name")
  emergencyContactPhone String?       @map("emergency_contact_phone")
  teamName              String?       @map("team_name")
  stuntPartnerOrGroup   String?       @map("stunt_partner_or_group")
  allergies             String?       @db.Text
  notes                 String?       @db.Text
  bookings              Booking[]
  sessions              UserSession[]
  passwordResetTokens   PasswordResetToken[]
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model ManagedCamp {
  id                 String   @id @default(cuid())
  slug               String   @unique
  title              String
  subtitle           String   @db.Text
  location           String
  venue              String
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  dateLabel          String?  @map("date_label")
  priceCents         Int      @map("price_cents")
  capacity           Int
  capacityText       String   @map("capacity_text")
  ages               String
  level              String
  coaches            Json
  coachModeLabel     String   @map("coach_mode_label")
  formatOptions      Json     @map("format_options")
  generalCampTime    String   @map("general_camp_time")
  overnightIncluded  Boolean  @default(true) @map("overnight_included")
  privateAvailable   Boolean  @default(true) @map("private_available")
  privatePaymentNote String   @db.Text @map("private_payment_note")
  coverImage         String   @map("cover_image")
  coverImageAlt      String   @map("cover_image_alt")
  bookingImage       String   @map("booking_image")
  bookingImageAlt    String   @map("booking_image_alt")
  gallery            Json
  privateOptions     Json     @map("private_options")
  focus              Json
  highlights         Json
  schedule           Json
  featured           Boolean  @default(false)
  bookingOpen        Boolean  @default(false) @map("booking_open")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([bookingOpen])
  @@index([featured])
  @@map("managed_camps")
}
